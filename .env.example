# The public recording route always uses deterministic demo data.
NEXT_PUBLIC_DEMO_MODE=true

# Required before private setup actions are exposed on a deployed instance.
# Optional when running on localhost.
HEADROOM_ACCESS_TOKEN=

# Required for POST /api/ingest.
HEADROOM_INGEST_TOKEN=

# Optional. Defaults to .headroom/snapshots.json.
HEADROOM_DATA_FILE=

# Optional OpenAI organization usage + costs integration.
# Keep this server-side. OpenAI's organization usage endpoints require an admin key.
OPENAI_ADMIN_KEY=
OPENAI_MONTHLY_BUDGET=100
OPENAI_PROJECT_LABEL=My product
